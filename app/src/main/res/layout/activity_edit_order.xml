<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/gray_light">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/ksk_primary" android:padding="16dp" android:elevation="4dp">
        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/edit_order_title" android:textSize="20sp" android:textStyle="bold" android:textColor="@color/white"/>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/card_bg" android:elevation="2dp" android:padding="20dp">
                <EditText android:id="@+id/etEditTitle" style="@style/KskEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Наименование" android:inputType="text" android:layout_marginBottom="12dp"/>
                <EditText android:id="@+id/etEditResponsible" style="@style/KskEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="@string/hint_responsible" android:inputType="text" android:layout_marginBottom="12dp"/>
                <EditText android:id="@+id/etEditStatus" style="@style/KskEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Статус" android:inputType="text"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <Button android:id="@+id/btnSave" style="@style/KskButton" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="16dp" android:text="@string/btn_save"/>
</LinearLayout>
