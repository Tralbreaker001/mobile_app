<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Базовая тема приложения -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Цвета из логотипа КСК -->
        <item name="colorPrimary">@color/ksk_primary</item>
        <item name="colorPrimaryDark">@color/ksk_primary_dark</item>
        <item name="colorAccent">@color/ksk_accent</item>
        
        <!-- Цвета текста -->
        <item name="android:textColorPrimary">@color/gray_dark</item>
        <item name="android:textColorSecondary">@color/gray</item>
    </style>
    
    <!-- Стиль для кнопок -->
    <style name="KskButton" parent="Widget.AppCompat.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:padding">14dp</item>
        <item name="android:background">@drawable/btn_primary</item>
    </style>
    
    <!-- Стиль для вторичных кнопок -->
    <style name="KskButton.Secondary">
        <item name="android:textColor">@color/gray_dark</item>
        <item name="android:background">@drawable/btn_secondary</item>
    </style>
    
    <!-- Стиль для EditText -->
    <style name="KskEditText" parent="Widget.AppCompat.EditText">
        <item name="android:textSize">15sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">@drawable/edit_text_bg</item>
        <item name="android:textColor">@color/gray_dark</item>
        <item name="android:textColorHint">@color/gray</item>
    </style>
    
    <!-- Стиль заголовков -->
    <style name="KskTitle">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/gray_dark</item>
    </style>
    
    <style name="KskSubtitle">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/gray</item>
    </style>
</resources>
